# Copy these to your shell environment. Do not commit real keys.

# Optional API backends
OPENAI_API_KEY=
GEMINI_API_KEY=
SARVAM_API_KEY=

# Model selection
PERSONA_TRANSCRIPTION_MODEL=whisper-1
PERSONA_SUMMARY_MODEL=gpt-4o-mini
PERSONA_GEMINI_MODEL=gemini-1.5-flash
PERSONA_SARVAM_MODEL=saaras:v3
PERSONA_SARVAM_MODE=transcribe
PERSONA_SARVAM_ENABLE_DIARIZATION=false
PERSONA_SARVAM_CHUNK_SECONDS=25
PERSONA_LOCAL_WHISPER_MODEL=small

# Local whisper performance tuning
PERSONA_LOCAL_WHISPER_BEAM_SIZE=2
PERSONA_LOCAL_WHISPER_CPU_THREADS=8

# Synthetic speaker labeling
PERSONA_SYNTHETIC_SPEAKER_COUNT=2
PERSONA_SPEAKER_TURN_GAP_SECONDS=1.6
